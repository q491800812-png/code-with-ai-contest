{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🚀 Run Streamlit Dashboard",
            "type": "python",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "app.py"
            ],
            "justMyCode": true,
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONUNBUFFERED": "1"
            }
        },
        {
            "name": "🧪 Run Unit Tests",
            "type": "python",
            "request": "launch",
            "module": "pytest",
            "args": [
                "test_dashboard.py",
                "-v",
                "--tb=short"
            ],
            "justMyCode": true,
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "📊 Run with Coverage",
            "type": "python",
            "request": "launch",
            "module": "pytest",
            "args": [
                "test_dashboard.py",
                "-v",
                "--cov=.",
                "--cov-report=html"
            ],
            "justMyCode": true,
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
    ]
}
