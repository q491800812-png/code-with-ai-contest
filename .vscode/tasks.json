{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "📦 Install Dependencies",
            "type": "shell",
            "command": "pip",
            "args": [
                "install",
                "-r",
                "requirements.txt"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "🚀 Run Streamlit Dashboard",
            "type": "shell",
            "command": "streamlit",
            "args": [
                "run",
                "app.py"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "runOptions": {
                "runOn": "folderOpen"
            }
        },
        {
            "label": "🧪 Run All Tests",
            "type": "shell",
            "command": "pytest",
            "args": [
                "test_dashboard.py",
                "-v",
                "--tb=short"
            ],
            "group": {
                "kind": "test"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "📊 Run Tests with Coverage",
            "type": "shell",
            "command": "pytest",
            "args": [
                "test_dashboard.py",
                "-v",
                "--cov=.",
                "--cov-report=html",
                "--cov-report=term-missing"
            ],
            "group": {
                "kind": "test"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "✨ Format Code with Black",
            "type": "shell",
            "command": "black",
            "args": [
                "app.py",
                "test_dashboard.py"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "🔍 Lint Code with Pylint",
            "type": "shell",
            "command": "pylint",
            "args": [
                "app.py"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
